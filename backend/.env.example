# ============================================================
# BookARide V2 — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# DATABASE (Neon PostgreSQL)
# Get this from: https://console.neon.tech → your project → Connection string
# Format: postgresql://user:password@host/dbname?sslmode=require
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/bookaride?sslmode=require

# ------------------------------------------------------------
# AUTH
# JWT_SECRET_KEY: Use a long random string in production.
# Generate one with: openssl rand -hex 32
# ------------------------------------------------------------
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
# JWT_ALGORITHM and JWT_EXPIRATION_HOURS have defaults (HS256, 24h)

# ------------------------------------------------------------
# STRIPE (Payments)
# Live keys from: https://dashboard.stripe.com/apikeys
# Webhook secret from: https://dashboard.stripe.com/webhooks
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------
# MAILGUN (Email)
# ------------------------------------------------------------
MAILGUN_API_KEY=key-...
MAILGUN_DOMAIN=bookaride.co.nz

# ------------------------------------------------------------
# TWILIO (SMS)
# ------------------------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+64...

# ------------------------------------------------------------
# GOOGLE
# Maps API Key: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API, Places API, Directions API, Geocoding API
# OAuth: https://console.cloud.google.com → OAuth 2.0 Client IDs
# ------------------------------------------------------------
GOOGLE_MAPS_API_KEY=AIza...
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ------------------------------------------------------------
# GEOAPIFY (Distance/routing fallback)
# https://www.geoapify.com/
# ------------------------------------------------------------
GEOAPIFY_API_KEY=...

# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------
PUBLIC_DOMAIN=https://bookaride.co.nz
PORT=10000

# Extra CORS origins (comma-separated), e.g. Vercel preview URLs
# EXTRA_CORS_ORIGINS=https://my-preview.vercel.app
