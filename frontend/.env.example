# ============================================================
# BookARide V2 Frontend — Environment Variables
# Copy to .env.local for local dev, or set in Vercel dashboard.
# ============================================================

# Backend API URL
# Local dev: http://localhost:10000
# Production: https://api.bookaride.co.nz  (or your Render service URL)
VITE_API_URL=http://localhost:10000

# Google Maps API Key (same key as backend, or a browser-restricted one)
VITE_GOOGLE_MAPS_API_KEY=AIza...
